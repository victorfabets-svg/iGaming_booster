{
  "name": "igaming-booster",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build:api && npm run build:worker",
    "build:api": "cd apps/api && npm run build",
    "build:worker": "tsc -p apps/worker/tsconfig.json",
    "test:e2e": "ts-node --esm tests/e2e/pipeline.e2e.ts",
    "test:e2e:event": "ts-node --esm tests/e2e/pipeline-event-driven.e2e.ts",
    "test:e2e:poll": "ts-node --esm tests/e2e/pipeline-real-event.e2e.ts",
    "test:e2e:true": "ts-node --esm tests/e2e/pipeline-true-e2e.e2e.ts",
    "test:e2e:process": "ts-node --esm tests/e2e/pipeline-process-e2e.e2e.ts"
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "typescript": "~5.8.0"
  }
}

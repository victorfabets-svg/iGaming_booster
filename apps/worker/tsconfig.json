{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": "../../",
    "noImplicitAny": false
  },
  "include": [
    "src/**/*",
    "../api/src/**/*",
    "../../shared/**/*"
  ],
  "exclude": ["node_modules", "dist", "../../shared/**/*.test.ts"]
}
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": "../../",
    "paths": {
      "@shared/*": ["shared/*"],
      "@domains/*": ["apps/api/src/domains/*"]
    },
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false
  },
  "include": [
    "src/**/*",
    "../api/src/domains/**/*",
    "shared/**/*"
  ]
}
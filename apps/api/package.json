{
  "name": "igaming-booster-api",
  "version": "1.0.0",
  "description": "iGaming Booster API",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/apps/api/src/server/index.js",
    "migrate": "ts-node -r tsconfig-paths/register src/scripts/run-migrations.ts",
    "replay:proof-validated": "ts-node -r tsconfig-paths/register src/scripts/replay-proof-validated.ts",
    "mint-dev-token": "ts-node -r tsconfig-paths/register scripts/mint-dev-token.ts",
    "seed:qa": "ts-node -r tsconfig-paths/register scripts/seed-qa.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.1.0",
    "fastify": "^4.25.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.8.0"
  }
}

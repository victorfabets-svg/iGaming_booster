run = "cd apps/web && npm install && npx vite --host 0.0.0.0 --port 5173"
entrypoint = "apps/web/main.tsx"
modules = ["nodejs-20"]

hidden = [".config", "node_modules"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "cd apps/web && npm install && npx vite --host 0.0.0.0 --port 5173"]
deploymentTarget = "static"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 3000
externalPort = 3000

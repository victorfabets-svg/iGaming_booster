# Build artifacts (rebuilt inside image)
**/node_modules
**/dist
**/.tsbuildinfo

# Frontend source (deployed separately on Vercel)
# But allow package.json for npm workspaces resolution
apps/web/**
!apps/web/package.json

# Tests + dev
tests
**/__tests__
**/*.test.ts

# Git / editors / OS
.git
.github
.vscode
.idea
.DS_Store
*.swp

# Docs / configs not needed at runtime
docs
README.md
*.md
.env*
.gitignore
